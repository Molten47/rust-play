  "query": "\n                SELECT id, sender_name, sender_email, summary, url_link, category, created_at, message_id\n                FROM priority_mail\n                WHERE (created_at, id) < ($1, $2)\n                ORDER BY created_at DESC, id DESC\n                LIMIT $3\n                ",
